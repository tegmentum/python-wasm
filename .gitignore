# Dependencies and build artifacts
deps/
# …but DO track WIT deps under cpython-ext/, bindings/, etc. They're vendored
# capability WITs, not the cpython submodule (which is what deps/ targets).
!**/wit/deps/
!**/wit/deps/**
*.wasm
*.log

# OS files
.DS_Store

# Editor files
*.swp
*~

# Web demo build artifacts
web/node_modules/
web/dist/
web/public/python-component/
web/public/stdlib.tar.gz

# Python bytecode caches
__pycache__/
*.pyc
*.pyo
# Built extension wheels (regenerated by scripts/build-extension-wheel.sh)
dist/wheels/

# Release tarballs (regenerated by scripts/package-release.sh)
dist/release/
dist/pypi/
# pip-wheel build/ staging dir
packaging/pypi/build/
packaging/pypi/src/python_wasm/data/
