package tegmentum:py-offload@0.1.0;

// Python-package catalog and backend SELECTION, reconciled with the
// webassembly-component-orchestration framework (`composectl`).
//
// Composition and execution are composectl's job: a worker is a content-addressed
// component (a CPython binding + capability components wired by a composectl
// `plan`), emitted and run via `composectl` (sys:compose `emit`/`exec` over the
// CAS `blobs`). This file does NOT re-implement any of that. It contributes only
// the python-facing pieces:
//   - `registry`: a catalog mapping a Python package to the worker backends that
//     can serve it, each identified by the composectl content digest of the
//     composed worker artifact. Populated from resolved envs + the per-family
//     `<family>-components` indexes — not re-curated here.
//   - `registry.select`: the per-package backend DECISION (pure catalog logic).
//     The chosen backend's digest is what a driver puts into a composectl plan;
//     composectl emits/execs it and the worker answers via the `offload` contract
//     (py-offload.wit). There is no parallel router/composer component.
//
// See docs/native-execution-and-parallelism.md (§4 the offload contract).

interface registry {
    use offload.{env-id, codec};

    // Execution tiers, in rough preference order.
    enum tier {
        in-wasm,      // Tier 0: a wasm32-wasip2 build (in-process or a girder actor)
        native-v86,   // Tier 1: python-wasm composed with v86 via `v86:posix/process` — the
                      // composed worker shells out to native Linux processes in the guest for
                      // unported native paths. See ~/git/v86/wit/posix.wit + docs/tier1-v86-integration.md.
        remote,       // off-box endpoint running either of the above
    }

    // One way to serve a package. `env` is the content digest of the composectl
    // composed-worker artifact for this tier (hex of sys:compose's CAS `digest`)
    // — the same identity composectl uses in plans/blobs, and the `env` a caller
    // passes to `offload.run`. A wasm build and a native build are different
    // artifacts -> different digests -> swappable behind one `offload` call.
    record backend {
        tier: tier,
        env: env-id,
    }

    // A callable the package advertises as offload-able.
    record entry-desc {
        entry: string,            // "module:callable" (matches an offload task.entry)
        doc: string,
        codecs: list<codec>,      // accepted codecs (empty = any the worker implements)
    }

    // A resolved Python distribution and how it can be served.
    record dist {
        name: string,             // e.g. "numpy"
        version: string,          // e.g. "2.1.0"
        // Serving backends in preference order (e.g. in-wasm before native-v86),
        // so publishing a wasm build of a native-only package is a catalog edit.
        backends: list<backend>,
    }

    record manifest {
        dist: dist,
        entries: list<entry-desc>,
    }

    // Catalog lookup.
    lookup: func(name: string) -> option<manifest>;
    list-packages: func() -> list<manifest>;

    // The routing DECISION (pure selection, no composition): the first backend
    // whose tier appears in `prefer` (honoring `prefer` order), else the dist's
    // first backend, else none. The caller hands the chosen backend's `env`
    // digest to a composectl plan; composectl composes and execs it.
    select: func(name: string, prefer: list<tier>) -> option<backend>;
}

// The catalog component: maps a package name -> serving backends + entries, in
// composectl digest terms. The single python-facing source of truth a driver
// consults before building a composectl plan. Composition/exec stay in composectl.
world catalog {
    export registry;
}
