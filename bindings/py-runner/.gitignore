# componentize-py build outputs (regenerated by build.sh).
pyrunner.wasm
runner.composed.wasm
# Generated by componentize-py.
gen/
__pycache__/

# The root .gitignore ignores any `deps/` (for deps/cpython); our WIT deps need
# to be tracked (componentize-py expects the wit/deps/<pkg>/ convention).
!wit/deps/
!wit/deps/**
