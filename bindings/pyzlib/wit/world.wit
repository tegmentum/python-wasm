package tegmentum:zlibpy@0.1.0;

// Python binding that CONSUMES the compression multiplexer capability over WIT.
// Imports tegmentum:compression-multiplexer/compression-dispatcher (satisfied by
// plugging compression_multiplexer.wasm via wac) and exposes a small entrypoint.
// This is python-wasm's `zlib` support: the stdlib-style `zlib` module routes to
// the already-built compression multiplexer rather than statically linking libz.
world zlib-demo {
    import tegmentum:compression-multiplexer/compression-dispatcher@0.1.0;
    export run: func() -> string;
}
